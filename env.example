# SQL Server connection
SQL_SERVER=localhost
SQL_INSTANCE=SQLEXPRESS         # named instance (optional, leave empty if not applicable)
SQL_DATABASE=MyDatabase
SQL_USER=my_user
SQL_PASSWORD=my_secure_password
SQL_ENCRYPT=false               # set to true for Azure SQL or mandatory SSL
SQL_TRUST_SERVER_CERT=true      # set to true for local/dev environments

# Security / filters
ALLOWED_TABLES=dbo.table1,dbo.table2,dbo.prefix_*   # wildcards with * at the end
MAX_ROWS=200                    # row limit per SELECT query

# Performance
SQL_QUERY_TIMEOUT=30000         # query timeout in milliseconds
SCHEMA_CACHE_TTL_MINUTES=5      # how long to cache schema results

# Audit log
AUDIT_LOG=false                 # set to true to enable audit logging
AUDIT_LOG_DIR=./logs            # folder where audit logs are written
